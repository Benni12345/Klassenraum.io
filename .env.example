# Game server WebSocket URL (baked into the client at build time).
# Use this on Vercel / Netlify when the Node server runs elsewhere.
# Alternative: copy public/config.json.example → public/config.json (no rebuild needed).
VITE_WS_URL=wss://your-game-server.example.com/ws

# --- Server only (npm start / Docker) ---
PORT=8080
DB_PATH=./data/klassenraum.db
# EVENT_MIN_GAP_MS=8000
# EVENT_MAX_GAP_MS=14000
