{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "packages/client/dist"
      }
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/ads.txt",
      "dest": "/ads.txt"
    },
    {
      "src": "/(about|guide|privacy|impressum)\\.html",
      "dest": "/$1.html"
    },
    {
      "src": "/pages.css",
      "dest": "/pages.css"
    },
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ]
}
